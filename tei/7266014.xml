   <text>
      <body>
         <div>
            <pb facs="#facs_1" n="1" xml:id="img_0001"/>
            <ab facs="#facs_1_tr_3">
               <lb facs="#facs_1_l" n="N001"/>[1]
               <lb facs="#facs_1_tr_3_tl_1" n="N002"/><Arts>Artistic</Arts> Styles 401:12
               <lb facs="#facs_1_tr_3_tl_3" n="N003"/>I. <Naturalism><hi style="text-decoration: underline;"><hi style="text-decoration: underline;">Naturalism</hi></hi></Naturalism>
               <lb facs="#facs_1_tr_3_tl_4" n="N004"/>1.-2. A Portrait from <rs type="person" key="van Lenbach, tillich_person_id__3917"><hi style="text-decoration: underline;">Franz v. Lenbach</hi></rs> on one
               <lb facs="#facs_1_tr_3_tl_5" n="N005"/>from <rs type="person" key="Sargent, tillich_person_id__3909"><hi style="text-decoration: underline;">Sargent</hi></rs> (or two from one of them)
               <lb facs="#facs_1_tr_3_tl_6" n="N006"/>3. <rs type="person" key="van Uhde, tillich_person_id__1964"><hi style="text-decoration: underline;">Fritz v. Uhde</hi></rs>. A <Religion>religious</Religion> picture (for instance "fare-
               <lb facs="#facs_1_tr_3_tl_7" n="N007"/>well of Tobias" or "Komm Herr Jesus!")
               <lb facs="#facs_1_tr_3_tl_8" n="N008"/>4. <rs type="person" key="Combet, tillich_person_id__406"><hi style="text-decoration: underline;">Courbet</hi></rs>. A landscape, preferably a forest or rock.
               <lb facs="#facs_1_tr_3_tl_9" n="N009"/>II.<hi style="text-decoration: underline;"> <Impressionism><hi style="text-decoration: underline;">Impressionism</hi></Impressionism></hi>
               <lb facs="#facs_1_tr_3_tl_10" n="N010"/>5. <rs type="person" key=", tillich_person_id__3034"><hi style="text-decoration: underline;">Manet.</hi></rs> "Horse-Race" or "Lunch in a Garden"
               <lb facs="#facs_1_tr_3_tl_11" n="N011"/>6.    "    Flowers or Fruits or a Street
               <lb facs="#facs_1_tr_3_tl_12" n="N012"/>7. <rs type="person" key="Renoir, tillich_person_id__1583"><hi style="text-decoration: underline;">Renoir</hi></rs>. A picture of the Seine or Boating
               <lb facs="#facs_1_tr_3_tl_14" n="N013"/>8.          "In the Loge" or "Picture of Sisley" or some
               <lb facs="#facs_1_tr_3_tl_15" n="N014"/>other portrait
            </ab>
            <pb facs="#facs_2" n="2" xml:id="img_0002"/>
            <ab facs="#facs_2_tr_3">
               <lb facs="#facs_2_l" n="N001"/>[2]
               <lb facs="#facs_2_tr_3_tl_1" n="N002"/>9. <rs type="person" key="Degas, tillich_person_id__442"><hi style="text-decoration: underline;">Degas</hi></rs>. Dancers (anyone of this subject)
               <lb facs="#facs_2_tr_3_tl_3" n="N003"/>10. <rs type="person" key="Monet, tillich_person_id__1343"><hi style="text-decoration: underline;">Monet</hi></rs>. Any landscape or street.
               <lb facs="#facs_2_tr_3_tl_4" n="N004"/>11.<rs type="person" key="Pissarro, tillich_person_id__3869"> <hi style="text-decoration: underline;">Pissarro</hi></rs>. Boulevard-scene
               <lb facs="#facs_2_tr_3_tl_5" n="N005"/>III. Transition to <Expressionism>Expressionism</Expressionism>.
               <lb facs="#facs_2_tr_3_tl_6" n="N006"/>12. <rs type="person" key=", tillich_person_id__2575"><hi style="text-decoration: underline;">Cézanne</hi></rs>. "L'Estaque" or any other landscape
               <lb facs="#facs_2_tr_3_tl_8" n="N007"/>with a lake, a town, baths, etc.
               <lb facs="#facs_2_tr_3_tl_9" n="N008"/>13.    "      "Still-Life" (one of many) [<hi style="text-decoration: underline;">very</hi> important!]
               <lb facs="#facs_2_tr_3_tl_11" n="N009"/>14.     "     Selfportrait (or other portrait)
               <lb facs="#facs_2_tr_3_tl_13" n="N010"/>15. <hi style="text-decoration: underline;"><rs type="person" key="Van Gogh, tillich_person_id__1984">Van Gogh</rs>.</hi> Landscape with trees! and sun (any)
               <lb facs="#facs_2_tr_3_tl_15" n="N011"/>16.     "     Selfportrait (or other portrait)
               <lb facs="#facs_2_tr_3_tl_16" n="N012"/>17.     "     Interieur of a Café (or similar)
            </ab>
            <pb facs="#facs_3" n="3" xml:id="img_0003"/>
            <ab facs="#facs_3_r">
               <lb facs="#facs_3_l" n="N001"/>[3]
               <lb facs="#facs_3_l_17" n="N002"/>18. <hi style="text-decoration: underline;"><rs type="person" key="Munch, tillich_person_id__1368">Edvard Munch</rs>.</hi> "The Horror" or similar objects
               <lb facs="#facs_3_l_24" n="N003"/>(as death-room, jalousy, few, etc.).
               <lb facs="#facs_3_l_31" n="N004"/>19.     "     "     Any landscape.
               <lb facs="#facs_3_l_38" n="N005"/>20. <rs type="person" key="Rousseau, tillich_person_id__3919"><hi style="text-decoration: underline;">Henri Rousseau</hi></rs>. Virginal Wood with animals (any!)
               <lb facs="#facs_3_l_45" n="N006"/><hi style="text-decoration: underline;">IV. German <Expressionism>Expressionism</Expressionism>.</hi>
               <lb facs="#facs_3_l_52" n="N007"/>21. <rs type="person" key="Nolde, tillich_person_id__1404"><hi style="text-decoration: underline;">Emil Nolde</hi></rs>: "Coming of the Holy Spirit" or "Lord's
               <lb facs="#facs_3_l_59" n="N008"/>Supper" or "Entombment" or "Adulteress"
               <lb facs="#facs_3_l_66" n="N009"/>22. <hi style="text-decoration: underline;"><rs type="person" key="Schmidt-Rottluff, tillich_person_id__1726">Schmidt-Rottluff</rs>.</hi> Any landscape
               <lb facs="#facs_3_l_73" n="N010"/>23.<hi style="text-decoration: underline;"> <rs type="person" key="Marc, tillich_person_id__1258">Franz Marc</rs>. </hi>"The tower of the blue horses" or
               <lb facs="#facs_3_l_80" n="N011"/>any other animal-picture
               <lb facs="#facs_3_l_87" n="N012"/>24. <hi style="text-decoration: underline;"><rs type="person" key="Kokoschka, tillich_person_id__3902">Oskar Kokoschka</rs> </hi>Portrait Forel or any other.
            </ab>
