            <pb facs="#facs_1" n="1" xml:id="img_0001"/>
            <ab facs="#facs_1_tr_1">
               <lb facs="#facs_1_tr_1_tl_1" n="N001"/><hi style="text-decoration: underline;">Examples of historical styles</hi>
               <lb facs="#facs_1_tr_1_tl_2" n="N002"/>I. Primitives, Stilo metaphysico, {Impressionism}
               <lb facs="#facs_1_tr_1_tl_4" n="N003"/>Pagan gods.
               <lb facs="#facs_1_tr_1_tl_5" n="N004"/>II. {Byzantine}, radical abstraction, <Cubism>Cubists</Cubism>,
               <lb facs="#facs_1_tr_1_tl_7" n="N005"/><rs type="person" key="Goya, tillich_person_id__3090">Goya</rs>, Callas,
               <lb facs="#facs_1_tr_1_tl_8" n="N006"/>III. <rs type="person" key="Daumier, tillich_person_id__3914">Daumier</rs>, <rs type="person" key=", tillich_person_id__728">Grosz</rs>, <rs type="person" key=", tillich_person_id__476">Dix</rs>, <rs type="person" key="Beckmann, tillich_person_id__172">Beckmann</rs>, <rs type="person" key="Masereel, tillich_person_id__3915">Maserell</rs>?
               <lb facs="#facs_1_tr_1_tl_11" n="N007"/>Futurism? Late Gothic
               <lb facs="#facs_1_tr_1_tl_13" n="N008"/>IV. <Ancient_Greece>Classical Greek</Ancient_Greece>, Renaissance, Rococco [sic.], Classicism.
               <lb facs="#facs_1_tr_1_tl_14" n="N009"/>Natural pantheism, <Impressionism>impressionism</Impressionism>
               <lb facs="#facs_1_l" n="N010"/>V. [Archaic Greeks?] <Expressionism>Expressionists</Expressionism>, Romanesk, Barock,
               <lb facs="#facs_1_l_1" n="N011"/><rs type="person" key=", Rembrandt">Rembrandt</rs>, {late Gothic}, Romanticism, Orphism
               <lb facs="#facs_1_l_2" n="N012"/>Futurism.
            </ab>
