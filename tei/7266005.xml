               <lb facs="#facs_4_l_13" n="N014"/><hi style="text-decoration: underline;">Primavera</hi>
            </ab>
            <pb facs="#facs_5" n="5" xml:id="img_0005"/>
            <ab facs="#facs_5_r">
               <lb facs="#facs_5_l" n="N001"/><hi style="text-decoration: underline;">Pictures V. </hi>
               <lb facs="#facs_5_l_1" n="N002"/>Late Quattrocento
               <lb facs="#facs_5_l_2" n="N003"/>1. <rs type="person" key="Perugino, tillich_person_id__3889">Perugino</rs>, Surrender of keys
               <lb facs="#facs_5_l_20" n="N004"/>{Picture of a boy}
               <lb facs="#facs_5_l_3" n="N005"/>Christ on the Cross
               <lb facs="#facs_5_l_4" n="N006"/>or similar material
               <lb facs="#facs_5_l_5" n="N007"/>2. <rs type="person" key="Pinturicchio, tillich_person_id__3973">Pinturicchio</rs>, <rs type="person" key="Pinturicchio, tillich_person_id__3973"><hi style="text-decoration: underline;">Pinturicchio</hi></rs>
               <lb facs="#facs_5_l_6" n="N008"/>Legend of Bernhard
               <lb facs="#facs_5_l_7" n="N009"/>Enea Silvio
               <lb facs="#facs_5_l_8" n="N010"/>3. <rs type="person" key="Carpaccio, tillich_person_id__3907">Carpaccio</rs>
               <lb facs="#facs_5_l_9" n="N011"/>Cycle of St. Ursula (1012), St. Catherine
               <lb facs="#facs_5_l_10" n="N012"/>StF
               <lb facs="#facs_5_l_11" n="N013"/>4. <rs type="person" key="Bellini, tillich_person_id__3027">Giovanni Bellini</rs>
               <lb facs="#facs_5_l_12" n="N014"/>Madonna
               <lb facs="#facs_5_l_13" n="N015"/><hi style="text-decoration: underline;">Crucification</hi> [sic.]
            </ab>
