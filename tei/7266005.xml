               <lb facs="#facs_4_l_9" n="N010"/>3. <rs type="person" key="Botticelli, tillich_person_id__263">Botticelli</rs>
               <lb facs="#facs_4_l_10" n="N011"/>2) Portraits (Guiliano Medici), Adoration of Magi 
               <lb facs="#facs_4_l_11" n="N012"/>[Madonna in round (Magnificat)]
