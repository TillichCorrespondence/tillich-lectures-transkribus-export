   <text>
      <body>
         <div>
            <pb facs="#facs_1" n="1" xml:id="img_0001"/>
            <ab facs="#facs_1_r">
               <lb facs="#facs_1_l" n="N001"/><hi style="text-decoration: underline;">Pictures. I</hi>
               <lb facs="#facs_1_l_1" n="N002"/>1. Romanesk building
               <lb facs="#facs_1_l_2" n="N003"/>a] Outside (with heavy walls and low towers)
               <lb facs="#facs_1_l_3" n="N004"/>b] Inside (low, cave-like, inner splendor)
               <lb facs="#facs_1_l_4" n="N005"/>2. Gothic building 
               <lb facs="#facs_1_l_5" n="N006"/>a] Outside (Reims, facade-West)
               <lb facs="#facs_1_l_6" n="N007"/>b] Inside (Saint Chapelle)
               <lb facs="#facs_1_l_7" n="N008"/>3. <Renaissance>Renaissance</Renaissance> building
               <lb facs="#facs_1_l_8" n="N009"/>
               <lb facs="#facs_1_l_9" n="N010"/>a] Outside (Palazzo Farnese, Spedale degli Innocenti <hi style="vertical-align: superscript;">Syedale Innocenti</hi>)
               <lb facs="#facs_1_l_10" n="N011"/>b] Inside (<hi style="text-decoration: underline;">S. Spirito <hi style="vertical-align: superscript;">Spiritu</hi> Florence</hi>, <hi style="text-decoration: underline;">Capella Pazzi</hi>)
            </ab>
            <pb facs="#facs_2" n="2" xml:id="img_0002"/>
            <ab facs="#facs_2_r">
               <lb facs="#facs_2_l" n="N001"/><hi style="text-decoration: underline;">Pictures II.</hi>
               <lb facs="#facs_2_l_1" n="N002"/><rs type="person" key="di Bondone, tillich_person_id__681">Giotto</rs> <hi style="text-decoration: underline;">emph. <rs type="person" key="di Bondone, tillich_person_id__681">Giotto</rs></hi><rs type="person" key="di Bondone, tillich_person_id__681"/>
               <lb facs="#facs_2_l_16" n="N003"/>book illustration
               <lb facs="#facs_2_l_2" n="N004"/>1. If possible some<hi style="text-decoration: underline;"> Romanesk</hi> miniatures (I. Archaic)
               <lb facs="#facs_2_l_17" n="N005"/>or typical Romanesque mural
               <lb facs="#facs_2_l_3" n="N006"/>2. Scenes of the legend of <hi style="text-decoration: underline;">St. Francis</hi> (2013)
               <lb facs="#facs_2_l_4" n="N007"/>3.     "     "     "     stories of the <hi style="text-decoration: underline;">gospels</hi> (2013)
               <lb facs="#facs_2_l_5" n="N008"/>(mostly form Padua and St. Croce Florence)
               <lb facs="#facs_2_l_6" n="N009"/><hi style="text-decoration: underline;">{for instance:</hi>}
               <lb facs="#facs_2_l_7" n="N010"/>{Dream of Innocent III.}
               <lb facs="#facs_2_l_8" n="N011"/>{Visitation of Elisabeth}
               <lb facs="#facs_2_l_9" n="N012"/>{Baptism of Christ}
               <lb facs="#facs_2_l_10" n="N013"/>{Appearance of St. Francis in Arles} 
               <lb facs="#facs_2_l_11" n="N014"/>{The betrothal of Maria}
               <lb facs="#facs_2_l_12" n="N015"/>{St. Francis preaching}
               <lb facs="#facs_2_l_13" n="N016"/>{<rs type="person" key="Martini, tillich_person_id__3029">Simone Martini</rs>}
               <lb facs="#facs_2_l_14" n="N017"/>4. One pictures [sic.] from <rs type="person" key="Martini, tillich_person_id__3029">Simone Martini</rs>
               <lb facs="#facs_2_l_15" n="N018"/>(showing the Lyric style of Siena)
            </ab>
            <pb facs="#facs_3" n="3" xml:id="img_0003"/>
            <ab facs="#facs_3_r">
               <lb facs="#facs_3_l" n="N001"/><hi style="text-decoration: underline;">Pictures III.</hi> {Early Renaissance} 
               <lb facs="#facs_3_l_1" n="N002"/><hi style="text-decoration: underline;">Transition</hi>
               <lb facs="#facs_3_l_2" n="N003"/>I. <rs type="person" key="Masaccio, tillich_person_id__3099">Masaccio</rs>
               <lb facs="#facs_3_l_3" n="N004"/>[Virgin with St. Anne and child]
               <lb facs="#facs_3_l_4" n="N005"/>Adoration
               <lb facs="#facs_3_l_5" n="N006"/>Spending alms
               <lb facs="#facs_3_l_6" n="N007"/>2. <rs type="person" key="Angelico, tillich_person_id__3888">Fra Angelico</rs>
               <lb facs="#facs_3_l_7" n="N008"/>Annunciatione, <hi style="text-decoration: underline;">St. Dominic</hi>
               <lb facs="#facs_3_l_8" n="N009"/>Murals of St. Marco (San Dominico) {Fiesole}
               <lb facs="#facs_3_l_9" n="N010"/>3. <rs type="person" key="Gozzoli, tillich_person_id__3969">Gozzoli</rs>: Franciscus-legend (2013)
               <lb facs="#facs_3_l_10" n="N011"/>4. <rs type="person" key="Lippi, tillich_person_id__3970">Lippi</rs>: Annunciatione
               <lb facs="#facs_3_l_11" n="N012"/>Virgin with child
               <lb facs="#facs_3_l_12" n="N013"/>different steps in [...]
               <lb facs="#facs_3_l_13" n="N014"/>St. Francis
            </ab>
            <pb facs="#facs_4" n="4" xml:id="img_0004"/>
            <ab facs="#facs_4_r">
               <lb facs="#facs_4_l" n="N001"/><hi style="text-decoration: underline;">Pictures IV. </hi>Early Quattrocento
               <lb facs="#facs_4_l_1" n="N002"/><rs type="person" key="della Francesca, tillich_person_id__3098"><hi style="text-decoration: underline;">Piero della Francesca</hi></rs>
               <lb facs="#facs_4_l_2" n="N003"/>1. <rs type="person" key="della Francesca, tillich_person_id__3098">Piero della Francesca</rs>
               <lb facs="#facs_4_l_3" n="N004"/>Montefeltro
               <lb facs="#facs_4_l_4" n="N005"/>Miracle of Cross
               <lb facs="#facs_4_l_5" n="N006"/>Queen of Saba (Sheba)
               <lb facs="#facs_4_l_6" n="N007"/>2. {<rs type="person" key="Ghirlandajo, tillich_person_id__3972">Chirlandajo (Chirlandajo) Ghirlandaio</rs>}
               <lb facs="#facs_4_l_7" n="N008"/>{Legend of St. Francis (or Gospels or OT - portraits)}
