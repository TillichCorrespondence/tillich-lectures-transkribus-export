               <lb facs="#facs_1_l_181" n="N026"/><rs type="person" key="Burtt, E.A.">Burtt, E. A.</rs>--The Metaphysical Foundations of Modern Science
               <lb facs="#facs_1_l_188" n="N027"/><rs type="person" key="Fromm, E.">Fromm, E.</rs>--Psychoanalysis and Religion
               <lb facs="#facs_1_l_195" n="N028"/><rs type="person" key="Heim, Karl">Heim, Karl</rs>--*Christian Faith and Natural Science
               <lb facs="#facs_1_l_202" n="N029"/><rs type="person" key="May, Rollo">May, Rollo</rs>--*Man's Search for Himself
               <lb facs="#facs_1_l_209" n="N030"/><rs type="person" key="Outler, Albert">Outler, Albert</rs>--Psychotherapy and the Christian Message
               <lb facs="#facs_1_l_216" n="N031"/><rs type="person" key="Roberts, David E.">Roberts, David E.</rs>--*Psychotherapy and the Christian View of Man
