            <p facs="#facs_1_r">
               <lb facs="#facs_1_l" n="N001"/>{1. Figurative}
               <lb facs="#facs_1_l_1" n="N002"/>1.
               <lb facs="#facs_1_l_2" n="N003"/><hi style="text-decoration: underline;"><rs type="keyword" ref="#Symbol">Symbolic</rs> <rs type="keyword" ref="#Arts">art</rs></hi>
               <lb facs="#facs_1_l_3" n="N004"/>1. <rs type="person" key=", tillich_person_id__295">Breughel </rs>II (Wilde Margrath)
               <lb facs="#facs_1_l_4" n="N005"/>2. <rs type="person" key=", tillich_person_id__496">Dürer</rs> 89 (Melancholia)
               <lb facs="#facs_1_l_5" n="N006"/>3. <rs type="person" key=", tillich_person_id__3095">Chirico</rs>. Art News 136 (The disquieting Muses)
